# Copy to .env.local for local dev. Values below are dev-friendly defaults.
# Items marked [PROD REQUIRED] are enforced at boot in production (src/lib/env.ts):
# the app refuses to start if they are missing/weak.

# [PROD REQUIRED] Postgres (use the Supabase POOLED connection string in prod)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gowild"

# Set to your deployed origin in prod (used for links); defaults to localhost
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# [PROD REQUIRED] Supabase Auth (magic-link). Optional locally — without these,
# the dashboard runs in dev header-shim mode.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Currently unused by the app; reserved for future server-side admin operations.
SUPABASE_SERVICE_ROLE_KEY=""
# Leave "false" everywhere except deliberate local dev. NEVER "true" in prod
# (it enables x-user-email impersonation). It is NOT inferred from NODE_ENV.
ALLOW_HEADER_AUTH="false"

# Provider adapters (optional; without creds the app serves the built-in sample
# schedule and the UI shows a "sample data" banner). Live data comes from fli.
PROVIDER_A_BASE_URL=""
PROVIDER_A_API_KEY=""
PROVIDER_B_BASE_URL=""
PROVIDER_B_API_KEY=""
FLI_ENABLED="true"
# Optional: defaults to the Vercel deployment URL when running on Vercel.
FLI_HTTP_BASE_URL=""
# [PROD REQUIRED on Vercel] Secret for the Python /api/fli/* endpoints. They
# FAIL CLOSED on Vercel when this is empty. Generate a long random value.
FLI_HTTP_SECRET=""
FLI_PYTHON_BIN="python3"

# Email (without RESEND_API_KEY, emails are logged as mocks instead of sent)
RESEND_API_KEY=""
ALERT_FROM_EMAIL="GoWild Explorer <alerts@example.com>"

# [PROD REQUIRED] Cron auth. Must be a strong, non-default value (>=16 chars,
# not "dev-secret") in prod. Vercel injects this as a Bearer token on cron runs.
# Generate with: openssl rand -hex 32
CRON_SECRET="dev-secret"
